name: ESP-Box Build

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v3

      - name: Setup ESP-IDF
        uses: espressif/esp-idf-action@v1
        with:
          version: v5.1
          target: esp32s3

      - name: Build ESP-IDF project
        working-directory: firmware
        run: |
          idf.py set-target esp32s3
          idf.py build
